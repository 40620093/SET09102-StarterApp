<ContentPage
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            x:Class="StarterApp.Views.AddItemPage"
            Title="Add Item">
            
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Add New Item"
                FontSize="20"
                FontAttributes="Bold" />

            
            <!--item title-->
            <Entry Placeholder="Item Title"
                Text="{Binding Title}" />
            
            <!--description-->
            <Entry Placeholder="Description"
                Text="{Binding Description}" />

            <!--category-->
            <Entry Placeholder="Category"
                Text="{Binding Category}" />
            
            <!--location-->
            <Entry Placeholder="Location"
                Text="{Binding Location}" />

            <!--daily rate-->
            <Entry Placeholder="Daily Rate"
                Keyboard="Numeric"
                Text="{Binding DailyRate}" />

        
            <Button Text="Save"
                Command="{Binding SaveCommand}" />
            
        </VerticalStackLayout>
            </ContentPage>